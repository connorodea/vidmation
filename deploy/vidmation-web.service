[Unit]
Description=VIDMATION Web Dashboard
After=network.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/var/www/vidmation
ExecStart=/usr/local/bin/uvicorn vidmation.web.app:create_app --factory --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=PATH=/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=multi-user.target
